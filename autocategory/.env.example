# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=autocategory
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=autocategory
DATABASE_URL=postgresql://autocategory:change_me_in_production@postgres:5432/autocategory

# ── Redis & Caching ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT Authentication ──────────────────────────────────────────
# Generate secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM (llama.cpp server) ──────────────────────────────────────
LLAMA_BASE_URL=http://llama-server:8080/v1
LLAMA_MODEL=gemma4-e4b
LLAMA_TEMPERATURE=0.1
LLAMA_MAX_TOKENS=512
LLAMA_TIMEOUT=30

# ── Embeddings ──────────────────────────────────────────
EMBEDDING_MODEL=Alibaba-NLP/gte-multilingual-base

# ── Qdrant ──────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=categories

# ── Classification ──────────────────────────────────────────────
THRESHOLD_AUTO_ASSIGN=0.90
THRESHOLD_PRESELECT=0.75
THRESHOLD_SUGGEST_TOP3=0.55

# ── App ─────────────────────────────────────────────────────────
TZ=Asia/Ho_Chi_Minh
CATEGORIES_JSON_PATH=/app/data/categories.json
LOG_LEVEL=INFO
LOG_FILE=/app/logs/autocategory.log
DATA_RETENTION_DAYS=90

# ── Features ────────────────────────────────────────────────────
ENABLE_IMAGE_GENERATION=true
ENABLE_TRAINING=true

# ── Rate Limiting ───────────────────────────────────────────────
DEFAULT_RATE_LIMIT_PER_MINUTE=60
DEFAULT_RATE_LIMIT_PER_DAY=1000

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ── Cloudflare (chạy scripts/setup_cloudflare.py một lần) ──────
# API Token: dash.cloudflare.com/profile/api-tokens
# Quyền cần: Cloudflare Tunnel:Edit + DNS:Edit
CF_API_TOKEN=
# Account ID: sidebar góc phải dash.cloudflare.com
CF_ACCOUNT_ID=
# Subdomain muốn dùng (VD: autocategory)
CF_SUBDOMAIN=autocategory
# Domain đã thêm vào Cloudflare (VD: yourdomain.com)
CF_DOMAIN=yourdomain.com
# Tên tunnel, mặc định autocategory
CF_TUNNEL_NAME=autocategory
OMNI_BASE_URL=https://vuatot.vn
